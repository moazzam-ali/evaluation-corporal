# ──────────────────────────────────────────────────────────────────────
# Evaluación Corporal — environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored; never commit real secrets.
# ──────────────────────────────────────────────────────────────────────

# ── Site URL — used for the results link in the coach's Telegram message ─
# No trailing slash. Defaults to https://evaluation-corporal.vercel.app.
SITE_URL="https://evaluation-corporal.vercel.app"

# ── Database — REQUIRED ────────────────────────────────────────────────
# Neon Postgres connection string. In the Neon dashboard:
#   Project → Connection Details → copy the "Pooled connection" string.
# Keep `?sslmode=require`; the app connects with SSL.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# ── OpenAI — REQUIRED (powers the body / image analysis) ───────────────
OPENAI_API_KEY="sk-..."

# ── Admin auth — REQUIRED (signs admin session cookies) ────────────────
# Generate a long random value, e.g.:  openssl rand -hex 32
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"

# ── Cloudinary — OPTIONAL (needed only for body/skin photo uploads) ────
# If left blank, the photo step is disabled and the rest of the app works.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET=""

# ── Elasticsearch / App Search — OPTIONAL (CRM indexing of results) ────
# If left blank, indexing is skipped silently.
ELASTIC_SERVER=""
ELASTIC_USER=""
ELASTIC_PASSWORD=""
ELASTIC_ENGINE=""

# ── Telegram bots ──────────────────────────────────────────────────────
# NOTE: Telegram bot tokens are NOT read from env. They live in the `bots`
# table and are populated by `npm run db:migrate`. Manage them there.
